{
  "name": "amazon-playwright-case-study",
  "version": "1.0.0",
  "description": "Automation case study using Playwright + TypeScript + Cucumber",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "npm run typecheck && cucumber-js",
    "test:bdd": "cucumber-js",
    "test:bdd:headed": "cross-env HEADED=true cucumber-js",
    "test:bdd:debug": "cross-env PWDEBUG=1 cucumber-js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "clean": "rimraf dist reports test-results"
  },
  "keywords": [
    "playwright",
    "typescript",
    "cucumber",
    "automation",
    "qa"
  ],
  "author": "Serghei Patrasco",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "playwright": "^1.59.1",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0"
  }
}
